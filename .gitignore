```gitignore
# ===========================
# Dependencies
# ===========================
node_modules/
.venv/
venv/
env/

# ===========================
# Environment Variables
# ===========================
.env
.env.*
!.env.example

# ===========================
# Python
# ===========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ===========================
# Next.js
# ===========================
.next/
out/

# ===========================
# Build
# ===========================
dist/
build/

# ===========================
# Logs
# ===========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ===========================
# OS Files
# ===========================
.DS_Store
Thumbs.db

# ===========================
# IDE
# ===========================
.vscode/
.idea/

# ===========================
# Cache
# ===========================
.cache/
*.tsbuildinfo

# ===========================
# Docker
# ===========================
*.pid

# ===========================
# MongoDB
# ===========================
mongodb-data/

# ===========================
# Misc
# ===========================
coverage/
tmp/
temp/
```
